# Copy this file to `.env` at the repository root and fill in values.
# The scripts in terraform/ will source `${workspaceFolder}/.env`.

# Atlassian credentials
BITBUCKET_USERNAME=your-email@example.com
BITBUCKET_TOKEN=your_api_token_here
# Optional: point to a non-cloud Bitbucket base URL
# BITBUCKET_BASE_URL=https://api.bitbucket.org/2.0

# Terraform variable for tests (sets TF_VAR_workspace when sourced)
TF_VAR_workspace=your-workspace-slug
